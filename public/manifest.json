{
  "manifest_version": 3,
  "name": "FastNote - Quick Notes",
  "version": "2.0.0",
  "description": "A fast and modern note-taking Chrome extension. Search, pin notes, and switch between light and dark themes.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/favicon-16x16.png",
      "32": "images/favicon-32x32.png",
      "48": "images/favicon-48x48.png",
      "128": "images/android-chrome-128x128.png"
    }
  },
  "icons": {
    "16": "images/favicon-16x16.png",
    "32": "images/favicon-32x32.png",
    "48": "images/favicon-48x48.png",
    "128": "images/android-chrome-128x128.png",
    "192": "images/android-chrome-192x192.png",
    "512": "images/android-chrome-512x512.png"
  },
  "permissions": [
    "storage"
  ],
  "author": "Furkan",
  "homepage_url": "https://github.com/furblood0/not-defteri-chrome-extension",
  "short_name": "FastNote"
}
